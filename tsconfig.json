{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ESNext"],
    "target": "esnext",
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "strict": true,
    "sourceMap": false,
    "esModuleInterop": true,
    "declaration": false
  },
  "include": ["./src/**/*.ts"]
}